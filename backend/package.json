{
  "name": "anko-shop-api",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create anko-shop-db",
    "db:migrate": "wrangler d1 migrations apply anko-shop-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply anko-shop-db --remote",
    "db:seed": "wrangler d1 execute anko-shop-db --local --file=./src/db/seed.sql",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.12.21"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250520.0",
    "wrangler": "^4.17.0"
  }
}
